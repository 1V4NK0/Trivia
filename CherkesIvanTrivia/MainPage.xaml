<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CherkesIvanTrivia.MainPage">

    <ContentPage.BackgroundColor>
        <!-- Hex color value #FF5733 -->
        <Color>#464E47</Color>
    </ContentPage.BackgroundColor>

    

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25"
            >
            <Label Text="Welcome to Trivia!" HorizontalOptions="Center" TextColor="White" Margin="0,20,0,0" FontSize="35" FontFamily="OpenSansRegular"/>
            <Button Text="Start Game" x:Name="StartGameBtn" Margin="0,70,0,0" WidthRequest="200" BackgroundColor="#568259" Clicked="StartGameBtn_Clicked" HorizontalOptions="Center"/>
            <Button Text="Settings" x:Name="SettingsBtn" WidthRequest="200" BackgroundColor="#568259" Clicked="SettingsBtn_Clicked"/>
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

